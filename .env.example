PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/rachanatmak
SESSION_SECRET=replace-with-a-long-random-secret

# Admin login
ADMIN_USERNAME=admin
# Use either ADMIN_PASSWORD for simple setup or ADMIN_PASSWORD_HASH for production.
ADMIN_PASSWORD=change-this-password
ADMIN_PASSWORD_HASH=

# Cloudinary
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Nodemailer SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@example.com
SMTP_PASS=your-app-password
MAIL_TO=artist@example.com
MAIL_FROM=Rachanatmak Website <your-email@example.com>
